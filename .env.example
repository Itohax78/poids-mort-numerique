# Variables d'environnement Poids Mort Numérique
# Copier ce fichier en .env et adapter les valeurs

# Clé secrète Flask (sessions). OBLIGATOIRE en production.
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=changeme-with-a-real-secret-key

# Environnement (development / production)
FLASK_ENV=development

# Chemin de la base de données SQLite (optionnel)
# POIDS_MORT_DB=/data/poids_mort.db
